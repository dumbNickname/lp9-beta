# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Both variables below are PUBLIC by design: they ship in the browser
# bundle. The anon key is RLS-protected (see DESIGN.md §16e/§16g). They
# still live in `.env` (not source) per the secret-hygiene convention.
#
# No Supabase personal access token and no DB password are needed for the
# branch-driven migration flow (DESIGN.md §16e).

# Supabase project URL, e.g. https://your-project-ref.supabase.co
VITE_SUPABASE_URL=

# Supabase anon/public API key (RLS-bounded; safe to ship in browser)
VITE_SUPABASE_ANON_KEY=

# Build-time base path for asset URLs. "/" for local dev and root
# deploys; set to e.g. "/lp9-beta/" when GitHub Pages serves from a
# sub-path. See app.config.ts.
BASE_PATH=/

